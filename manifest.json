{
    "manifest_version": 3,
    "name": "Ali-img-upload",
    "author":"Yukuii",
    "description": "Ali-img-upload is a chrome extension for uploading images to Aliyun OSS.",
    "version": "1.0.0",
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
          "matches": ["<all_urls>"],
          "js": ["js/popup.js"]
        }
      ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
          "48": "icons/icon48.png",
          "128": "icons/icon128.png"
        }
      },
    "permissions": [
        "activeTab",
        "storage",
        "clipboardRead",
        "<all_urls>"
    ],
    "host_permissions": ["<all_urls>"]
}
